{
    "name": "sme-copilot-backend",
    "version": "1.0.0",
    "description": "SME Cash-Flow Risk Copilot — API backend (owns the SQLite DB, proxies compute to the Python engine)",
    "scripts": {
        "dev": "nodemon --exec ts-node src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "migrate": "ts-node src/database/migrate.ts",
        "seed": "ts-node src/database/seed.ts"
    },
    "dependencies": {
        "axios": "^1.13.2",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "sqlite3": "^5.1.7"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.6",
        "nodemon": "^3.0.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    }
}
